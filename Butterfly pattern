#include <iostream>
using namespace std;

// Butterfly pattern

int main()
{
    int n = 5;

    for (int i = 0; i < n; i++)
    {
        int num = 1; // Intializing here cuz every line starts with 1.
        for (int j = 0; j <= i; j++)
        {
            cout << num;
            num++;
        }
        for(int j = 0 ; j<2*(n-i-1); j++){
            cout << " ";
        }
        for (int j = i + 1; j >= 1; j--)
        {
            cout << j;
        }
        cout << endl;
    }
}
