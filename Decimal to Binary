#include <iostream>
using namespace std;

// Program to convert decimal to binary

int main()
{
    int ans = 0;
    int pow = 1;
    int n;
    cout << "Enter the value of n : ";
    cin >> n;
    while (n > 0)
    {
        int rem = n % 2;
        n = n / 2;
        ans += rem * pow;
        pow *= 10;
    }
    cout << "Binary number is : "<< ans << endl;
}
