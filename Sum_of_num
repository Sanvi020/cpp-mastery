#include <iostream>
using namespace std;

// Program to print sum of numbers from 1 to N

int main()
{
    int n ;
    cout << "Enter the value of n: ";
    cin >> n;
    int sum = 0 ;
    
    for(int i = 1; i<=n ; i++){
        sum += i;
    }
    cout << "The sum of numbers from 1 to " << n << " is :" << sum;
}
