#include <iostream>
using namespace std;

// Pyramid Pattern with alphabets

int main()
{
    int n = 5;
    for(int i = 0 ; i<n; i++){
        char ch = 'A';

        for(int j = 0; j < n-i-1 ; j++){
            cout << " ";
        }
        for(int j = 0 ; j<=i ; j++){
            cout << ch ;
            ch++;
        }
        ch -= 2;
        for(int j = 0 ; j<i; j++){
            cout << ch;
            ch--;
        }
        cout << endl;
    }

}
