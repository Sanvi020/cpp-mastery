#include <iostream>
using namespace std;

// Function to check if a number is prime or not

int prime(int n){
    int flag = 0;
    for(int i = 2 ; i<n; i++){
        if(n%i == 0){
            flag = 1;
            break;
        }
    }
    if(flag == 1){
        cout << "Not a prime number "<< endl;
    }
    else{
        cout << "Prime Number"<< endl;
    }
    return 0;
}

int main()
{
    cout << prime(23);
}
