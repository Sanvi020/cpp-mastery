#include <iostream>
using namespace std;

//  Triangle pattern with numbers 

int main()
{
    int n = 4;
    int num = 1; // Intilizing cuz evry digit starts with a new line

    for(int i = 0; i<n ; i++){
        for(int j = 0; j<i+1 ; j++){
            cout << num << " ";
        }
        num ++;
        cout << endl;
    }
}
