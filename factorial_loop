#include <iostream>
using namespace std;

// Program to print factorial of a number n

int main()
{
    int n;
    cout << "Enter the value of n : ";
    cin >> n;

    int fact = 1;
    for(int i=1 ; i<=n ; i++){
        fact *= i ;
    }
    cout << "The factorial of number " << n << " is " << fact ;
}
