#include <iostream>
using namespace std;

// A flipping Number pattern

int main()
{
    int n =5;
    int start =1;

    for(int i = 0 ; i<2*n-1 ; i++){
        if(i%2==0){
            start = 0;
        }
        else{
            start = 1;
        }
        for(int j = 0 ; j<i ; j++){
            cout << start << " ";
            start = 1 - start ;
        }
        cout << endl;
    }
}
