#include <iostream>
using namespace std;

//  Triangle pattern with alphabets 

int main()
{
    int n = 4;
    char ch = 'A'; // Intilizing cuz evry digit starts with a new line

    for(int i = 0; i<n ; i++){
        for(int j = 0; j<i+1 ; j++){
            cout << ch << " ";
        }
        ch ++;
        cout << endl;
    }
}
