#include <iostream>
using namespace std;

//  Number pattern with changing digits in each line 

int main()
{
    int n = 3;
    int a = 1;      // Every line is starting with new digit 

    for(int i = 1; i<=n; i++){
        for(int j = 1 ; j<=n ; j++){
            cout << a << " ";
            a++;
        }
        cout << endl;
    }
}
