#include <iostream>
using namespace std;

// Program to print sum of all numbers from 0 to n divisible by 3

int main()
{
    int n;
    cout << "Enter the value of n : ";
    cin >> n;
    int sum = 0;

    for(int i = 0; i<=n ; i++){
        if(i%3==0){
            sum += i;
        }
    }
    cout << "The sum of numbers divisible by 3 from 0 to "<< n << " is : "<<sum ;
}
